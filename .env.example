# Public browser-safe Supabase values only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional comma-separated emails with unrestricted UI for testing.
# Real enforcement should live in Supabase RLS/profile role checks.
NEXT_PUBLIC_ADMIN_EMAILS=

# Optional browser-safe Google values. Restrict API keys in Google Cloud by domain/app before publishing.
NEXT_PUBLIC_GOOGLE_PROJECT_ID=
NEXT_PUBLIC_GOOGLE_PROJECT_NUMBER=
NEXT_PUBLIC_GOOGLE_API_KEY=
